{
  "expo": {
    "name": "SSRCH: интеллектуальный подбор персонала",
    "slug": "LR1",
    "description": "Приложение для поиска вакансий и подбора персонала с использованием искусственного интеллекта",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ssrch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.black9mirror.LR1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2A2A2A",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.black9mirror.LR1",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2A2A2A"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Разрешить SSRCH доступ к вашему местоположению для поиска вакансий рядом с вами"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Разрешить SSRCH доступ к галерее для загрузки аватара"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4CAF50"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f34648f0-cd90-478a-95f4-a4aa4b02730f"
      }
    }
  }
}
